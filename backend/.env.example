# =====================================================================
# GR EXPRESSO - Variáveis de Ambiente
# Copie este arquivo para ".env" e preencha com seus dados reais
# =====================================================================

# Ambiente
NODE_ENV=development
PORT=3000

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gr_expresso
DB_CONNECTION_LIMIT=10
# Deixe "false" para MySQL local. Mude para "true" se a hospedagem do banco
# exigir conexão criptografada (ex: Railway, PlanetScale).
DB_SSL=false

# Autenticação - troque por um valor único e secreto em produção
JWT_SECRET=troque-este-valor-por-um-segredo-unico-e-aleatorio

# CORS - URL do frontend (se servido separadamente)
FRONTEND_URL=http://localhost:5500

# Integrações futuras (deixar em branco até configurar)
TELEMETRIA_ETS2_ENDPOINT=
TRUCKSBOOK_API_KEY=
TRUCKY_API_KEY=
